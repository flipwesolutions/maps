{
  "expo": {
    "name": "Flipwi Maps",
    "slug": "flipwi-maps",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flipwisolutions.maps",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Flipwi Maps needs your location to show you on the map and help you navigate.",
        "NSLocationAlwaysUsageDescription": "Flipwi Maps needs your location for turn-by-turn navigation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.flipwisolutions.maps",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "imageWidth": 280
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Flipwi Maps needs location access to show you on the map."
        }
      ],
      "expo-status-bar",
      "expo-font"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
