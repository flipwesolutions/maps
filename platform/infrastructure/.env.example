# Flipwi Solutions — self-hosted platform (zero external map providers)

COMPOSE_PROJECT_NAME=flipwi-maps

# --- PostgreSQL + PostGIS ---
POSTGIS_HOST=postgres
POSTGIS_PORT=5432
POSTGIS_DATABASE=flipwi_maps
POSTGIS_USER=flipwi
POSTGIS_PASSWORD=flipwi_dev_change_me

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- OpenSearch (Pelias backend) ---
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200

# --- Pelias (search, autocomplete, geocode) ---
PELIAS_HOST=http://pelias-api:4000
SEARCH_HOST=search.maps.flipwi.local

# --- Valhalla (routing, ETA, matrix) ---
VALHALLA_HOST=http://valhalla:8002
ROUTING_HOST=routing.maps.flipwi.local

# --- Martin vector tile server ---
TILESERVER_HOST=http://martin:3000
TILES_HOST=tiles.maps.flipwi.local

# --- Map style service ---
MAP_STYLE_HOST=http://nginx:80
MAPS_HOST=maps.maps.flipwi.local

# --- API Gateway ---
API_GATEWAY_HOST=http://api-gateway:3001
API_HOST=api.maps.flipwi.local
API_PORT=3001
CLIENT_API_KEYS=dev-client-key

# --- Object storage (MinIO — tile backups, offline packs) ---
OBJECT_STORAGE_HOST=http://minio:9000
BACKUP_STORAGE=/backups

# --- NGINX reverse proxy ---
NGINX_HTTP_PORT=80
