# Flipwi Solutions API — self-hosted only (no external providers)

PORT=3001
CLIENT_API_KEYS=dev-client-key

# Pelias on our infrastructure
PELIAS_HOST=http://localhost:4000

# Valhalla on our infrastructure
VALHALLA_HOST=http://localhost:8002

# Martin vector tiles (used in map style substitution)
TILESERVER_HOST=http://localhost:3000

# PostGIS
POSTGIS_HOST=localhost
POSTGIS_PORT=5432
POSTGIS_DATABASE=flipwi_maps
POSTGIS_USER=flipwi
POSTGIS_PASSWORD=flipwi

REDIS_HOST=localhost
REDIS_PORT=6379

RATE_LIMIT_PER_MIN=120

# GIS Admin panel
ADMIN_API_KEY=dev-admin-key-change-me
