# Flipwi Solutions Maps — mobile client (self-hosted platform only)
# No Mapbox, Google, MapTiler, CARTO, or any external map provider.

# Our API gateway (search, reverse geocode, routing, map styles)
# Production: http://api.maps.flipwi.local
# Dev on phone (same Wi-Fi): http://<YOUR-PC-LAN-IP>:3001
EXPO_PUBLIC_API_GATEWAY_HOST=http://api.maps.flipwi.local

# Our vector tile server (Martin / TileServer GL)
EXPO_PUBLIC_TILESERVER_HOST=http://tiles.maps.flipwi.local

# Our MapLibre style service (optional if styles served via API gateway)
EXPO_PUBLIC_MAP_STYLE_HOST=http://maps.maps.flipwi.local

# Client API key issued by Flipwi Solutions (not an external provider key)
EXPO_PUBLIC_MAPS_API_KEY=dev-client-key

# Map tiles: OSM raster by default (works without Docker).
# Set to true only after Martin vector tiles are deployed.
# EXPO_PUBLIC_USE_VECTOR_TILES=true
